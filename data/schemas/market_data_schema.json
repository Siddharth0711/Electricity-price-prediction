{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Market Data Schema",
    "description": "Schema for electricity market data including MCP and demand",
    "type": "object",
    "properties": {
        "timestamp": {
            "type": "string",
            "format": "date-time"
        },
        "mcp_inr_per_mwh": {
            "type": "number",
            "minimum": 0,
            "description": "Market Clearing Price in INR per MWh"
        },
        "demand_mw": {
            "type": "number",
            "minimum": 0,
            "description": "Total electricity demand in MW"
        },
        "supply_mw": {
            "type": "number",
            "minimum": 0,
            "description": "Total electricity supply in MW"
        },
        "reserve_margin_percent": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
        },
        "congestion_cost_inr": {
            "type": "number",
            "minimum": 0
        },
        "ancillary_services_cost_inr": {
            "type": "number",
            "minimum": 0
        }
    },
    "required": [
        "timestamp",
        "mcp_inr_per_mwh",
        "demand_mw",
        "supply_mw"
    ]
}